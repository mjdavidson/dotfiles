#!/usr/bin/env bash
# Smart tmux window naming with worktree detection

COMMAND="$1"
CURRENT_PATH="$2"

# Claude sets its process title to version number, map it back
if [[ "$COMMAND" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  COMMAND="claude"
fi

# Get icon from nerdwin
ICON=$(nerdwin "$COMMAND")

# Get smart directory name
get_smart_name() {
  local path="$1"
  local dir_name=$(basename "$path")

  local branch=$(cd "$path" 2>/dev/null && git rev-parse --abbrev-ref HEAD 2>/dev/null)

  # Format a branch name as "ENT-1234 slug" if it contains a Linear-style ID.
  format_branch() {
    local b="$1"
    if [[ "$b" =~ ([A-Za-z]+)-([0-9]+)-([^/]+)$ ]]; then
      local id="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}"
      local slug="${BASH_REMATCH[3]}"
      echo "$(echo "$id" | tr '[:lower:]' '[:upper:]') $slug"
    elif [[ "$b" =~ ([A-Za-z]+-[0-9]+)$ ]]; then
      echo "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]'
    else
      echo "$b"
    fi
  }

  # Worktree detection (.git is a file, not a directory)
  if [ -f "$path/.git" ]; then
    local parent_dir=$(dirname "$path")
    local parent_name=$(basename "$parent_dir")
    local grandparent_dir=$(dirname "$parent_dir")

    # claude --work-tree pattern: <project>/.claude/worktrees/<worktree>
    if [ "$parent_name" = "worktrees" ] && [ "$(basename "$grandparent_dir")" = ".claude" ]; then
      local project=$(basename "$(dirname "$grandparent_dir")")
      if [ -n "$branch" ] && [ "$branch" != "HEAD" ]; then
        echo "$project ($(format_branch "$branch"))"
      else
        echo "$project ($dir_name)"
      fi
      return
    fi

    # Bare-repo worktree pattern: <project>/.bare + <project>/<worktree>
    if [ -d "$parent_dir/.bare" ] && [ -n "$branch" ]; then
      local project=$(basename "$parent_dir")
      echo "$project ($(format_branch "$branch"))"
      return
    fi
  fi

  # Plain repo: format the branch if we have one
  if [ -n "$branch" ] && [ "$branch" != "HEAD" ]; then
    format_branch "$branch"
    return
  fi

  # Default: just show directory name
  echo "$dir_name"
}

NAME=$(get_smart_name "$CURRENT_PATH")

# Output icon and name
echo "$ICON $NAME"
